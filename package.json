{
  "name": "galactic-spacefarer",
  "version": "1.0.0",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "test": "vitest",
    "test:unit": "vitest --project=unit",
    "test:int": "vitest --project=int",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "npx vitest run --coverage --testTimeout=10000",
    "test:ci:debug": "NODE_OPTIONS=\"--trace-warnings --unhandled-rejections=strict\" npx vitest run --coverage --testTimeout=50000",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,cds,json,md}\"",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@sap/cds": "^9",
    "@vitest/coverage-istanbul": "^4.1.0",
    "nodemailer": "^8.0.2"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@sap/cds-dk": "^9.8.1",
    "@sap/eslint-plugin-cds": "^4",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "@vitest/ui": "^4.1.0",
    "chai-as-promised": "^8.0.2",
    "chai-subset": "^1.3.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
