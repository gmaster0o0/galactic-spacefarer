{
  "name": "galactic-spacefarer",
  "version": "1.0.0",
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "data/galactic.db"
        }
      }
    }
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "test": "jest",
    "lint": "cds lint",
    "format": "prettier --write \"**/*.{js,cds,json,md}\"",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "@sap/eslint-plugin-cds": "^4",
    "@cap-js/cds-types": "^0.16.0",
    "@types/node": "^24.0.0",
    "tsx": "^4",
    "typescript": "^5",
    "@cap-js/cds-typer": ">=0.1"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
